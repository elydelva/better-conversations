{
  "name": "better-conversations",
  "private": true,
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/elydelva/better-conversations"
  },
  "workspaces": {
    "packages": ["packages/*", "packages/examples/*", "apps/*"],
    "catalog": {
      "typescript": "^5.7.0"
    },
    "catalogs": {
      "build": {
        "tsup": "8.0.0"
      },
      "agnostic": {
        "@better-agnostic/adapter": "^0.0.3",
        "@better-agnostic/adapter-drizzle": "^0.0.3",
        "@better-agnostic/errors": "^0.0.3",
        "@better-agnostic/handler": "^0.0.3",
        "@better-agnostic/handler-express": "^0.0.3",
        "@better-agnostic/handler-fastify": "^0.0.3",
        "@better-agnostic/handler-hono": "^0.0.3",
        "@better-agnostic/handler-next": "^0.0.3",
        "@better-agnostic/schema": "^0.0.3"
      }
    }
  },
  "scripts": {
    "build": "bun run --filter './packages/*' --filter './packages/examples/*' --filter './apps/*' build",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "publish:packages": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "bun-types": "^1.2.0",
    "@changesets/cli": "^2.27.10",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "typescript": "catalog:",
    "zod": "^4.3.6"
  },
  "lint-staged": {
    "*.{ts,tsx}": "biome check --write"
  },
  "overrides": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0"
  }
}
