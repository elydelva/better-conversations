{
  "name": "better-conversations",
  "private": true,
  "version": "0.0.0",
  "workspaces": {
    "packages": ["packages/*"],
    "catalog": {
      "typescript": "^5.7.0"
    },
    "catalogs": {
      "build": {
        "tsup": "8.0.0"
      }
    }
  },
  "scripts": {
    "build": "bun run --filter './packages/*' build",
    "test": "bun test",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "changeset": "changeset",
    "version": "changeset version",
    "publish:packages": "changeset publish",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.27.10",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "typescript": "catalog:"
  },
  "lint-staged": {
    "*.{ts,tsx}": "biome check --write"
  }
}
